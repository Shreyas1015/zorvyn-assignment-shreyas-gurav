{
  "info": {
    "name": "Zorvyn Finance Dashboard API",
    "description": "Complete API collection for Zorvyn Finance Dashboard Backend (v1).\n\n**Setup:**\n1. Run \"Login Admin\" first — it auto-sets the accessToken\n2. All protected requests use {{accessToken}} automatically\n3. Refresh tokens are sent as httpOnly cookies automatically\n4. Switch roles by running Login Analyst or Login Viewer\n\n**Seed credentials:**\n- admin@zorvyn.com / Password1\n- analyst@zorvyn.com / Password1\n- viewer@zorvyn.com / Password1\n\n**Auth model:** Access token (15 min, Bearer header) + Refresh token (7 days, httpOnly cookie).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "createdUserId",
      "value": ""
    },
    {
      "key": "createdRecordId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has status ok', () => {",
                  "    pm.expect(pm.response.json().status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Verify server is running. No auth required."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "    console.log('Access token set for role:', res.data.user.role);",
                  "}",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has accessToken', () => pm.expect(res.data.accessToken).to.be.a('string'));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "pm.test('Has meta.timestamp', () => pm.expect(res.meta.timestamp).to.be.a('string'));",
                  "pm.test('Role is ADMIN', () => pm.expect(res.data.user.role).to.eql('ADMIN'));",
                  "pm.test('User ID is UUID', () => pm.expect(res.data.user.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/));",
                  "pm.test('Set-Cookie contains refreshToken', () => {",
                  "    const cookies = pm.response.headers.get('Set-Cookie');",
                  "    pm.expect(cookies).to.include('refreshToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@zorvyn.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login as ADMIN. Auto-sets {{accessToken}}. Refresh token set as httpOnly cookie."
          }
        },
        {
          "name": "Login Analyst",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "    console.log('Access token set for role:', res.data.user.role);",
                  "}",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "pm.test('Role is ANALYST', () => pm.expect(res.data.user.role).to.eql('ANALYST'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"analyst@zorvyn.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login as ANALYST. Auto-sets {{accessToken}}. Can read records + dashboard, cannot write."
          }
        },
        {
          "name": "Login Viewer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "    console.log('Access token set for role:', res.data.user.role);",
                  "}",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "pm.test('Role is VIEWER', () => pm.expect(res.data.user.role).to.eql('VIEWER'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"viewer@zorvyn.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login as VIEWER. Auto-sets {{accessToken}}. Can only access dashboard endpoints."
          }
        },
        {
          "name": "Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(res.data.accessToken).to.be.a('string'));",
                  "pm.test('Default role VIEWER', () => pm.expect(res.data.user.role).to.eql('VIEWER'));",
                  "pm.test('No passwordHash', () => pm.expect(res.data.user.passwordHash).to.be.undefined);",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "pm.test('User ID is UUID', () => pm.expect(res.data.user.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"SecurePass1\",\n  \"name\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new user. Default role: VIEWER. Password must have min 8 chars, uppercase, lowercase, number."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has new accessToken', () => pm.expect(res.data.accessToken).to.be.a('string'));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "",
                  "if (res.success && res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "    console.log('Access token refreshed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Exchange refresh token (httpOnly cookie) for a new access token + rotated refresh token. Uses refresh token rotation with family-based compromise detection."
          }
        },
        {
          "name": "Get Current User (Me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user email', () => pm.expect(res.data.email).to.be.a('string'));",
                  "pm.test('Has user role', () => pm.expect(res.data.role).to.be.a('string'));",
                  "pm.test('No passwordHash', () => pm.expect(res.data.passwordHash).to.be.undefined);",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Get the currently authenticated user's profile."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "pm.collectionVariables.set('accessToken', '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Revoke refresh token and clear cookie. Logs TOKEN_REVOKED security event."
          }
        },
        {
          "name": "Login — Wrong Password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Has error.code', () => {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.error.code).to.be.a('string');",
                  "});",
                  "pm.test('Generic error message', () => {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.error.message).to.eql('Invalid credentials');",
                  "});",
                  "pm.test('Has meta.requestId', () => pm.expect(pm.response.json().meta.requestId).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@zorvyn.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Verify generic error message — doesn't reveal if email exists. Logs AUTH_FAILURE security event. After 5 failures, account is locked for 15 min."
          }
        },
        {
          "name": "Register — Validation Error (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has error.code', () => {",
                  "    pm.expect(pm.response.json().error.code).to.be.a('string');",
                  "});",
                  "pm.test('Has field-level details', () => {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.error.details).to.be.an('array').that.is.not.empty;",
                  "});",
                  "pm.test('Has meta.requestId', () => pm.expect(pm.response.json().meta.requestId).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"ab\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Verify Zod validation returns field-level error details. Password must be min 8 chars with uppercase, lowercase, and number."
          }
        }
      ]
    },
    {
      "name": "Auth Flow",
      "description": "End-to-end authentication flow: Login → Refresh → Me → Logout. Run requests in order.",
      "item": [
        {
          "name": "1. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has accessToken', () => pm.expect(res.data.accessToken).to.be.a('string'));",
                  "pm.test('Has meta', () => {",
                  "    pm.expect(res.meta.requestId).to.be.a('string');",
                  "    pm.expect(res.meta.timestamp).to.be.a('string');",
                  "});",
                  "pm.test('Set-Cookie contains refreshToken', () => {",
                  "    const cookies = pm.response.headers.get('Set-Cookie');",
                  "    pm.expect(cookies).to.include('refreshToken');",
                  "});",
                  "",
                  "if (res.success && res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@zorvyn.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Step 1: Authenticate and receive access token (Bearer) + refresh token (httpOnly cookie)."
          }
        },
        {
          "name": "2. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('New accessToken issued', () => pm.expect(res.data.accessToken).to.be.a('string'));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "pm.test('Refresh token rotated (new Set-Cookie)', () => {",
                  "    const cookies = pm.response.headers.get('Set-Cookie');",
                  "    pm.expect(cookies).to.include('refreshToken');",
                  "});",
                  "",
                  "if (res.success && res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Step 2: Use refresh token cookie to get a new access token. Old refresh token is invalidated (rotation)."
          }
        },
        {
          "name": "3. Get Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user profile', () => {",
                  "    pm.expect(res.data.email).to.be.a('string');",
                  "    pm.expect(res.data.role).to.be.a('string');",
                  "});",
                  "pm.test('User ID is UUID', () => pm.expect(res.data.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Step 3: Verify the refreshed access token works by fetching current user profile."
          }
        },
        {
          "name": "4. Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "pm.collectionVariables.set('accessToken', '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Step 4: Revoke refresh token, clear cookie, log TOKEN_REVOKED event."
          }
        },
        {
          "name": "5. Refresh After Logout (Should Fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Has error.code', () => pm.expect(pm.response.json().error.code).to.be.a('string'));",
                  "pm.test('Has meta.requestId', () => pm.expect(pm.response.json().meta.requestId).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Step 5: Verify refresh token was revoked — should return 401."
          }
        }
      ]
    },
    {
      "name": "Users (Admin Only)",
      "item": [
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Has pagination', () => pm.expect(res.pagination).to.have.property('total'));",
                  "pm.test('Data is array', () => pm.expect(res.data).to.be.an('array'));",
                  "pm.test('No passwordHash exposed', () => {",
                  "    res.data.forEach(u => pm.expect(u.passwordHash).to.be.undefined);",
                  "});",
                  "pm.test('IDs are UUIDs', () => {",
                  "    res.data.forEach(u => pm.expect(u.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/));",
                  "});",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user data', () => {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.data).to.have.property('email');",
                  "});",
                  "pm.test('Has meta.requestId', () => pm.expect(pm.response.json().meta.requestId).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{createdUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{createdUserId}}"]
            },
            "description": "Get user by UUID. Run 'Create User' first to populate {{createdUserId}}."
          }
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "pm.test('Role set correctly', () => pm.expect(res.data.role).to.eql('ANALYST'));",
                  "pm.test('ID is UUID', () => pm.expect(res.data.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/));",
                  "pm.test('Has meta.requestId', () => pm.expect(res.meta.requestId).to.be.a('string'));",
                  "if (res.data.id) pm.collectionVariables.set('createdUserId', res.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"created-user@example.com\",\n  \"password\": \"SecurePass1\",\n  \"name\": \"Created User\",\n  \"role\": \"ANALYST\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            }
          }
        },
        {
          "name": "Update User (Change Status)",
          "event": [
            {
              "listen": "test",
