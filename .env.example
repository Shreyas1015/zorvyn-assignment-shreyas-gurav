# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zorvyn?schema=public"

# JWT (access: short-lived, refresh: long-lived)
JWT_SECRET="your-access-token-secret-min-32-characters"
JWT_REFRESH_SECRET="your-refresh-token-secret-min-32-characters"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# CORS (comma-separated origins)
CORS_ORIGIN="http://localhost:3000"

# Rate Limiting (optional — defaults: 100 req / 15 min)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging (optional — debug | info | warn | error)
LOG_LEVEL="info"
